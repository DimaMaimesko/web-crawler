<mxfile host="app.diagrams.net">
  <diagram name="Components" id="components-page">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="cmp-title" value="Web Crawler — Component Architecture" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="cmp-cmd" value="cmd/crawler (package main)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cmp-main" value="main()&#10;seed, workers,&#10;maxDepth, rate interval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cmp-crawler" value="internal/crawler" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="70" width="360" height="330" as="geometry" />
        </mxCell>
        <mxCell id="cmp-crawl" value="Crawl()&#10;orchestrator + drain loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="390" y="110" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cmp-worker" value="worker()&#10;goroutine pool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="560" y="110" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cmp-rl" value="RateLimiter&#10;(time.Ticker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="390" y="200" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cmp-iface" value="&#171;interface&#187;&#10;Fetcher" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1f0ff;strokeColor=#2b6cb0;" vertex="1" parent="1">
          <mxGeometry x="560" y="195" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cmp-adapter" value="realFetcher&#10;(adapter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="475" y="300" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cmp-tracker" value="internal/tracker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cmp-vt" value="VisitedTracker&#10;map[string]bool + RWMutex&#10;MarkVisited / HasVisited / Count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cmp-fetcher" value="internal/fetcher" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#b85450;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="440" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="cmp-fae" value="FetchAndExtract()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="390" y="480" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cmp-fp" value="fetchPage()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="390" y="550" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cmp-el" value="extractLinks()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="495" y="550" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cmp-ru" value="resolveURL()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="600" y="550" width="90" height="50" as="geometry" />
        </mxCell>

        <mxCell id="cmp-net" value="Internet&#10;(target website)" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="790" y="470" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="DefaultFetcher()" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-main" target="cmp-adapter">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="Crawl(f, seed, ...)" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-main" target="cmp-crawl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="spawns" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-crawl" target="cmp-worker">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="throttle" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-crawl" target="cmp-rl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="dedup URLs" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-crawl" target="cmp-vt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="calls" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-worker" target="cmp-iface">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="implements" style="endArrow=block;endFill=0;dashed=1;html=1;rounded=0;" edge="1" parent="1" source="cmp-adapter" target="cmp-iface">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="delegates" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-adapter" target="cmp-fae">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-fae" target="cmp-fp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-fae" target="cmp-el">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-fae" target="cmp-ru">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="HTTP GET" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cmp-fp" target="cmp-net">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Concurrency" id="concurrency-page">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="con-title" value="Concurrency &amp; Data Flow (worker pool)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="600" height="30" as="geometry" />
        </mxCell>

        <mxCell id="con-seed" value="seed URL&#10;depth = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="con-jobs" value="jobs chan&#10;CrawlTask (buf 100)" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="240" y="85" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="con-pool" value="Worker Pool (maxWorkers goroutines)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;dashed=1;verticalAlign=top;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="220" height="200" as="geometry" />
        </mxCell>
        <mxCell id="con-w1" value="worker 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="100" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="con-w2" value="worker 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="150" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="con-wn" value="worker N" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="210" width="160" height="40" as="geometry" />
        </mxCell>

        <mxCell id="con-rl" value="RateLimiter&#10;Wait()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="530" y="300" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="con-results" value="results chan&#10;PageResult (buf 100)" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="800" y="150" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="con-drain" value="Crawl drain loop&#10;pending &gt; 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e6ffe6;strokeColor=#2f855a;" vertex="1" parent="1">
          <mxGeometry x="810" y="290" width="160" height="90" as="geometry" />
        </mxCell>

        <mxCell id="con-check" value="MarkVisited(link)&#10;already visited?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="560" y="430" width="180" height="90" as="geometry" />
        </mxCell>

        <mxCell id="con-collect" value="allResults[]&#10;(error == &quot;&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="850" y="430" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="con-drop" value="discard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="330" y="440" width="100" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ce1" value="go func()" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-seed" target="con-jobs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce2" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-jobs" target="con-w1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce3" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-jobs" target="con-w2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce4" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-jobs" target="con-wn">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce5" value="Wait()" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-w2" target="con-rl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce6" value="PageResult" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-w2" target="con-results">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce7" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-results" target="con-drain">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce8" value="new links" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-drain" target="con-check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce9" value="success" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-drain" target="con-collect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce10" value="no → enqueue (pending++)" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-check" target="con-jobs">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="465" />
              <mxPoint x="330" y="115" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="ce11" value="yes → skip" style="endArrow=classic;html=1;" edge="1" parent="1" source="con-check" target="con-drop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

